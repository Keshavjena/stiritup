# Stir It Up Environment Variables

# The URL of your persistent Socket.io backend server (e.g. Render/Railway URL)
# Keep empty or omit this in local development to automatically connect to localhost:3000
NEXT_PUBLIC_SOCKET_SERVER_URL=

# Permitted CORS origins for the backend Socket.io server
# e.g., https://stiritup.vercel.app,http://localhost:3000 (comma-separated list)
# Default is '*' if omitted.
ALLOWED_ORIGINS=

# Optional: Groq API Key for AI-generated custom game prompts
GROQ_API_KEY=
